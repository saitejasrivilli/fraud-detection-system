# Database Configuration
DATABASE_URL=postgresql://fraud_user:fraud_password_123@localhost:5432/fraud_detection

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO

# Application
DEBUG=False
ENVIRONMENT=development

# API Configuration
API_TITLE=Fraud Detection System
API_VERSION=1.0.0

# Database Connection Pool
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Monitoring
MONITORING_ENABLED=True
METRICS_ENABLED=True

# Alerting
ALERT_EMAIL=admin@fraud.com
ALERT_ENABLED=True

# Model Configuration
MODEL_PATH=/app/models
RESULTS_PATH=/app/results

# Production Settings (uncomment for production)
# DEBUG=False
# ENVIRONMENT=production
# DATABASE_URL=postgresql://user:password@prod-db:5432/fraud_detection
# REDIS_URL=redis://prod-cache:6379
# SECRET_KEY=<strong-random-key>
